{
  "manifest_version": 3,
  "name": "AwaJobs Clipper",
  "version": "1.0",
  "description": "Envoie une offre d'emploi vers ton dashboard AwaJobs en un clic.",
  "browser_specific_settings": {
    "gecko": {
      "id": "awajobs-clipper@awajobs"
    }
  },
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon48.png"
  },
  "content_scripts": [
    {
      "matches": ["*://www.linkedin.com/jobs/*", "*://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
